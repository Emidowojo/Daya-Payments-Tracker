# App
NODE_ENV=development
PORT=3000
DATA_DIR=./data
STATE_BACKEND=local
STATE_TABLE_NAME=

# Local by default. Use sqs later when deployed to AWS.
QUEUE_MODE=local
SQS_QUEUE_URL=
AWS_REGION=us-east-1

# Daya
DAYA_BASE_URL=https://api.sandbox.daya.co
DAYA_API_KEY=replace_with_sandbox_key
DAYA_WEBHOOK_SECRET=dev_webhook_secret

# Keep true outside local demos.
DAYA_REQUIRE_WEBHOOK_SIGNATURE=true

# Start in mock mode until sandbox credentials are available.
DAYA_MOCK_MODE=true

# Worker
WORKER_POLL_INTERVAL_MS=3000
WORKER_BATCH_SIZE=10
WORKER_ONCE=false
